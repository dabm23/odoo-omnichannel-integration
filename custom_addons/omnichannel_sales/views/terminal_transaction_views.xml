<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_terminal_transaction" model="ir.actions.act_window">
        <field name="name">Transacciones de Terminales</field>
        <field name="res_model">terminal.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_omnichannel_root" name="Terminales Omnicanal" sequence="10"/>
    <menuitem id="menu_terminal_transactions" name="Transacciones" parent="menu_omnichannel_root" action="action_terminal_transaction" sequence="10"/>

    <record id="view_terminal_transaction_list" model="ir.ui.view">
        <field name="name">terminal.transaction.list</field>
        <field name="model">terminal.transaction</field>
        <field name="arch" type="xml">
            <list string="Transacciones">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'processed'" 
                       decoration-danger="state == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_terminal_transaction_form" model="ir.ui.view">
        <field name="name">terminal.transaction.form</field>
        <field name="model">terminal.transaction</field>
        <field name="arch" type="xml">
            <form string="Transacción">
                <header>
                    <button name="action_process_transaction" 
                            string="Procesar Contabilidad" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processed,error"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_move" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-book" 
                                invisible="not move_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Ver Asiento</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="terminal_identifier" readonly="state != 'draft'"/>
                            <field name="journal_id" required="1" readonly="state != 'draft'"/> 
                        </group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="move_id" invisible="1"/> 
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>